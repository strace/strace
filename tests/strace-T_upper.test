. "${srcdir=.}/init.sh"

T_opt="${1:--T}"

run_prog ../sleep-timing 0 "$TIMING_FILE"
run_strace -a24 "${T_opt}" -enanosleep ../sleep-timing 1 "$TIMING_FILE"
match_grep
check_strace_syscall_time "${T_opt}"
